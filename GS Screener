      <div class="score-label">Overall Score</div>
      <div class="score-verdict" id="score-verdict">--</div>
    </div>
    <div class="score-right" id="score-right">
      <div class="score-metric"><div class="score-metric-label">Price</div><div class="score-metric-value" id="sm-price">--</div><div class="score-metric-sub" id="sm-change">--</div></div>
      <div class="score-metric"><div class="score-metric-label">Market Cap</div><div class="score-metric-value" id="sm-mcap">--</div><div class="score-metric-sub" id="sm-sector">--</div></div>
      <div class="score-metric"><div class="score-metric-label">52W Range</div><div class="score-metric-value" id="sm-52w">--</div><div class="score-metric-sub" id="sm-52w-sub">--</div></div>
