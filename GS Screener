  </div>

  <!-- Row 1: Technical + Fundamental -->
  <div class="section-grid">
    <div class="panel">
      <div class="panel-header"><span class="panel-title">TECHNICAL ANALYSIS</span><span class="panel-badge badge-blue" id="tech-badge">LOADING</span></div>
      <div class="panel-body">
        <div class="gauge-row" style="margin-bottom:12px;">
          <div class="gauge"><div class="gauge-value" id="rsi-val">--</div><div class="gauge-label">RSI</div><div class="gauge-sub" id="rsi-signal">--</div></div>
          <div class="gauge"><div class="gauge-value" id="macd-val">--</div><div class="gauge-label">MACD</div><div class="gauge-sub" id="macd-signal">--</div></div>
          <div class="gauge"><div class="gauge-value" id="trend-val">--</div><div class="gauge-label">TREND</div><div class="gauge-sub" id="trend-signal">--</div></div>
          <div class="gauge"><div class="gauge-value" id="vol-val">--</div><div class="gauge-label">VOL</div><div class="gauge-sub" id="vol-signal">--</div></div>
