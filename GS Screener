    <span class="quick-pill" onclick="quickPick('META')">META</span>
    <span class="quick-pill" onclick="quickPick('AMZN')">AMZN</span>
    <span class="quick-pill" onclick="quickPick('GOOGL')">GOOGL</span>
    <span class="quick-pill" onclick="quickPick('JPM')">JPM</span>
    <span class="quick-pill" onclick="quickPick('PLTR')">PLTR</span>
    <span class="quick-pill" onclick="quickPick('COIN')">COIN</span>
