      <div id="ai-verdict-content">
        <div class="ai-thinking"><div class="ai-spinner"></div> Waiting for stock data...</div>
      </div>
    </div>
  </div>

</div>

<script>
const FINNHUB_KEY = 'd8ec5fhr01qth3cgkulgd8ec5fhr01qth3cgkum0';
const AV_KEY = 'E8W6DEJJDVSWSDEG';

setInterval(() => {
  document.getElementById('clock').textContent = new Date().toLocaleTimeString('en-US',{hour12:true});
}, 1000);

function quickPick(t) { document.getElementById('ticker-input').value = t; analyze(); }
document.getElementById('ticker-input').addEventListener('keypress', e => { if(e.key==='Enter') analyze(); });
function setLoading(pct, msg) {
  document.getElementById('loading-bar').style.width = pct+'%';
  document.getElementById('loading-status').textContent = msg;
}

async function fhGet(path) {
  const r = await fetch(`https://finnhub.io/api/v1${path}&token=${FINNHUB_KEY}`);
  return r.json();
}

async function analyze() {
  const ticker = document.getElementById('ticker-input').value.trim().toUpperCase();
  if (!ticker) return;
  document.getElementById('loading-overlay').classList.remove('hidden');
  setLoading(0, 'Connecting to market data...');
  try {
    document.getElementById('analysis-panel').classList.remove('visible');
    setLoading(10, `Fetching ${ticker} quote...`);
    const [quote, profile, metrics, candles, recommendation, target, insider, earnings] = await Promise.all([
      fhGet(`/quote?symbol=${ticker}`),
      fhGet(`/stock/profile2?symbol=${ticker}`),
      fhGet(`/stock/metric?symbol=${ticker}&metric=all`),
      (async()=>{ const to=Math.floor(Date.now()/1000); const from=to-86400*90; return fhGet(`/stock/candle?symbol=${ticker}&resolution=D&from=${from}&to=${to}`); })(),
      fhGet(`/stock/recommendation?symbol=${ticker}`),
      fhGet(`/stock/price-target?symbol=${ticker}`),
      fhGet(`/stock/insider-transactions?symbol=${ticker}`),
      fhGet(`/stock/earnings?symbol=${ticker}&limit=4`)
    ]);
    setLoading(60, 'Processing indicators...');
    if (!quote.c || quote.c === 0) throw new Error('Not found');
    setLoading(75, 'Building analysis...');
    const analysis = buildAnalysis(ticker, quote, profile, metrics, candles, recommendation, target);
    renderAll(ticker, quote, profile, metrics, candles, recommendation, target, analysis, insider, earnings);
    setLoading(90, 'Running AI deep analysis...');
    runAIAnalysis(ticker, quote, profile, metrics, analysis, target, recommendation);
    setLoading(100, 'Complete');
    setTimeout(() => {
      document.getElementById('loading-overlay').classList.add('hidden');
      document.getElementById('analysis-panel').classList.add('visible');
      document.getElementById('analysis-panel').scrollIntoView({behavior:'smooth'});
    }, 300);
  } catch(e) {
    document.getElementById('loading-overlay').classList.add('hidden');
    alert(`Could not find data for "${ticker}". Check the ticker and try again.`);
  }
}

function calcRSI(closes, p=14) {
  if (closes.length < p+1) return 50;
  let g=0,l=0;
  for(let i=closes.length-p;i<closes.length;i++){const d=closes[i]-closes[i-1];if(d>0)g+=d;else l+=Math.abs(d);}
  const ag=g/p,al=l/p;
  return al===0?100:Math.round(100-(100/(1+ag/al)));
}

function calcMACD(closes) {
  if(closes.length<26) return {bullish:false,val:0};
  const ema=(arr,p)=>{const k=2/(p+1);let e=arr[0];for(let i=1;i<arr.length;i++)e=arr[i]*k+e*(1-k);return e;};
  const r=closes.slice(-35);
  const val=ema(r,12)-ema(r,26);
  return {bullish:val>0,val:val.toFixed(3)};
}

function calcSMA(closes,p) { return closes.length>=p?closes.slice(-p).reduce((a,b)=>a+b,0)/p:null; }

function fmtB(n) {
  if(!n)return'—';
  if(Math.abs(n)>=1e12)return'$'+(n/1e12).toFixed(2)+'T';
  if(Math.abs(n)>=1e9)return'$'+(n/1e9).toFixed(2)+'B';
  if(Math.abs(n)>=1e6)return'$'+(n/1e6).toFixed(2)+'M';
  return'$'+n.toFixed(0);
}
function fmtN(n,d=2){return n!=null&&!isNaN(n)?n.toFixed(d):'—';}
function fmtPct(n){return n!=null&&!isNaN(n)?(n>0?'+':'')+n.toFixed(1)+'%':'—';}
function scoreColor(s){return s>=75?'var(--green)':s>=55?'var(--gold2)':s>=40?'var(--gold)':'var(--red)';}

function buildAnalysis(ticker, quote, profile, metrics, candles, recommendation, target) {
  const m=metrics?.metric||{};
  const closes=candles?.c||[];
  const rsi=calcRSI(closes);
  const macd=calcMACD(closes);
  const sma20=calcSMA(closes,20);
  const sma50=calcSMA(closes,50);
  const sma200=calcSMA(closes,200);
  const price=quote.c;
  const pe=m['peNormalizedAnnual'],roe=m['roeTTM'],margin=m['netProfitMarginTTM'],debtEq=m['totalDebt/totalEquityAnnual'];

  let techScore=50;
  if(rsi>30&&rsi<70)techScore+=10;
  if(rsi<40)techScore+=15;
  if(rsi>70)techScore-=10;
  if(macd.bullish)techScore+=15;
  if(sma20&&price>sma20)techScore+=8;
  if(sma50&&price>sma50)techScore+=8;
  if(sma200&&price>sma200)techScore+=4;
  if(quote.dp>0)techScore+=5;
  techScore=Math.max(5,Math.min(98,techScore));

  let fundScore=50;
  if(pe&&pe>0&&pe<30)fundScore+=15;
  if(pe&&pe>30&&pe<60)fundScore+=5;
  if(pe&&pe>60)fundScore-=10;
  if(roe&&roe>15)fundScore+=15;
  if(roe&&roe>30)fundScore+=5;
  if(margin&&margin>15)fundScore+=10;
  if(margin&&margin>25)fundScore+=5;
  if(debtEq&&debtEq<50)fundScore+=10;
  if(debtEq&&debtEq>200)fundScore-=15;
  fundScore=Math.max(5,Math.min(98,fundScore));

  let valScore=50;
  const pb=m['pbAnnual'];
  if(pe&&pe>0&&pe<20)valScore+=20;
  else if(pe&&pe<35)valScore+=10;
  else if(pe&&pe>50)valScore-=15;
  if(pb&&pb<3)valScore+=15;
  if(pb&&pb>10)valScore-=10;
  valScore=Math.max(5,Math.min(98,valScore));

  let sentScore=50;
  if(recommendation&&recommendation.length>0){
    const l=recommendation[0];
    const total=(l.strongBuy||0)+(l.buy||0)+(l.hold||0)+(l.sell||0)+(l.strongSell||0);
    if(total>0){const bull=((l.strongBuy||0)*2+(l.buy||0))/total*100;sentScore=Math.round(bull*0.8+20);}
  }
  if(target?.targetMean&&price){
    const up=(target.targetMean-price)/price*100;
    if(up>20)sentScore+=15;else if(up>10)sentScore+=8;else if(up<0)sentScore-=15;
  }
  sentScore=Math.max(5,Math.min(98,sentScore));

  const overall=Math.round(techScore*0.25+fundScore*0.30+valScore*0.25+sentScore*0.20);
  let verdict,verdictColor,signalClass;
  if(overall>=75){verdict='STRONG BUY';verdictColor='var(--green)';signalClass='signal-buy';}
  else if(overall>=62){verdict='BUY';verdictColor='var(--green)';signalClass='signal-buy';}
  else if(overall>=45){verdict='HOLD';verdictColor='var(--gold2)';signalClass='signal-hold';}
  else if(overall>=32){verdict='UNDERPERFORM';verdictColor='var(--red)';signalClass='signal-sell';}
  else{verdict='SELL';verdictColor='var(--red)';signalClass='signal-sell';}

  return {techScore,fundScore,valScore,sentScore,overall,verdict,verdictColor,signalClass,rsi,macd,sma20,sma50,sma200};
}

function metricRow(name,value,barPct,barColor,note='') {
  return `<div class="metric-row">
    <span class="metric-name">${name}</span>
    <div class="metric-bar-wrap"><div class="metric-bar"><div class="metric-bar-fill" style="width:${Math.min(100,Math.max(0,barPct))}%;background:${barColor};"></div></div></div>
    <span class="metric-val">${value}</span>
    ${note?`<span class="metric-note" style="margin-left:8px;">${note}</span>`:''}
  </div>`;
}

