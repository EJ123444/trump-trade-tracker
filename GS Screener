function renderInsider(insider) {
  const transactions = insider?.data || insider || [];
  const recent = Array.isArray(transactions) ? transactions.slice(0,6) : [];
  if (!recent.length) {
    document.getElementById('insider-badge').textContent = 'NO DATA';
    document.getElementById('insider-metrics').innerHTML = '<div style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">No recent insider transactions</div>';
    return;
  }
  const buys = recent.filter(t => t.transactionType === 'P - Purchase' || t.change > 0);
  const sells = recent.filter(t => t.transactionType === 'S - Sale' || t.change < 0);
  document.getElementById('insider-badge').className = `panel-badge ${buys.length > sells.length ? 'badge-green' : 'badge-red'}`;
  document.getElementById('insider-badge').textContent = buys.length > sells.length ? 'NET BUYING' : 'NET SELLING';
  document.getElementById('insider-metrics').innerHTML = `
    <div style="font-family:var(--font-mono);font-size:10px;color:var(--muted2);margin-bottom:10px;letter-spacing:1px;">LAST ${recent.length} INSIDER TRANSACTIONS</div>
    ${recent.map(t => {
      const isBuy = t.transactionType?.includes('P') || t.change > 0;
      const shares = Math.abs(t.change || t.share || 0).toLocaleString();
      const val = t.transactionPrice ? '$' + (Math.abs(t.change||0) * t.transactionPrice).toLocaleString('en-US',{maximumFractionDigits:0}) : '';
      return `<div class="insider-row">
        <div>
          <div class="insider-name">${t.name || 'Insider'}</div>
          <div class="insider-meta">${t.filingDate||''} · ${t.transactionType||''}</div>
        </div>
        <div style="text-align:right;">
          <div class="insider-val" style="color:${isBuy?'var(--green)':'var(--red)'}">${isBuy?'+':'-'}${shares} shares</div>
          ${val?`<div style="font-family:var(--font-mono);font-size:10px;color:var(--muted2);">${val}</div>`:''}
        </div>
      </div>`;
    }).join('')}
  `;
}

function renderEarnings(earnings, ticker) {
  const data = Array.isArray(earnings) ? earnings : [];
  if (!data.length) {
    document.getElementById('earnings-badge').textContent = 'NO DATA';
    document.getElementById('earnings-metrics').innerHTML = '<div style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">No earnings data available</div>';
    return;
  }
  const beats = data.filter(e => e.actual > e.estimate).length;
  const total = data.filter(e => e.actual != null).length;
  const beatRate = total > 0 ? Math.round(beats/total*100) : null;
  document.getElementById('earnings-badge').className = `panel-badge ${beatRate >= 75 ? 'badge-green' : beatRate >= 50 ? 'badge-gold' : 'badge-red'}`;
  document.getElementById('earnings-badge').textContent = beatRate != null ? `${beatRate}% BEAT RATE` : 'DATA';
  document.getElementById('earnings-metrics').innerHTML = `
    <div style="font-family:var(--font-mono);font-size:10px;color:var(--muted2);margin-bottom:10px;letter-spacing:1px;">RECENT EARNINGS (EPS)</div>
    ${data.slice(0,4).map(e => {
      const beat = e.actual != null && e.estimate != null ? e.actual > e.estimate : null;
      const surprise = e.actual != null && e.estimate != null ? ((e.actual - e.estimate)/Math.abs(e.estimate)*100).toFixed(1) : null;
      return `<div class="metric-row">
        <span class="metric-name">${e.period||'—'}</span>
        <span class="metric-val" style="color:${beat===true?'var(--green)':beat===false?'var(--red)':'var(--muted2)'}">
          $${e.actual?.toFixed(2)||'—'} ${beat===true?'✓ BEAT':beat===false?'✗ MISS':''}
        </span>
        <span class="metric-note">${surprise!=null?(surprise>0?'+':'')+surprise+'% vs est $'+(e.estimate?.toFixed(2)||'—'):''}</span>
      </div>`;
    }).join('')}
    ${beatRate!=null?`<div style="margin-top:12px;font-family:var(--font-mono);font-size:11px;color:var(--muted2);">Beat rate last ${total} quarters: <span style="color:${beatRate>=75?'var(--green)':beatRate>=50?'var(--gold2)':'var(--red)'}">${beatRate}%</span></div>`:''}
  `;
}

function buildVerdictText(ticker, quote, profile, metrics, analysis, target) {
  const m=metrics?.metric||{};
  const pe=m['peNormalizedAnnual'],roe=m['roeTTM'];
  const upside=target?.targetMean?((target.targetMean-quote.c)/quote.c*100).toFixed(1):null;
  const name=profile.name||ticker;
  let text=`${name} scores ${analysis.overall}/100 on our institutional framework — a composite of technical momentum, fundamental quality, valuation, and analyst consensus. `;
  if(analysis.overall>=75)text+=`This is a high-conviction buy setup. `;
  else if(analysis.overall>=62)text+=`The risk/reward is favorable for long positions. `;
  else if(analysis.overall>=45)text+=`The stock presents a mixed picture with both strengths and concerns. `;
  else text+=`Caution is warranted at current levels. `;
  if(pe)text+=`Trading at ${pe.toFixed(1)}x earnings${pe<20?' — a compelling valuation':pe>60?' — a demanding multiple that requires execution':' — in line with market averages'}. `;
  if(roe)text+=`Return on equity of ${roe.toFixed(1)}% ${roe>20?'reflects a competitively advantaged business model':'is adequate but leaves room for improvement'}. `;
  if(upside)text+=`Consensus analyst price target implies ${upside}% ${parseFloat(upside)>0?'upside':'downside'} from current levels. `;
  if(analysis.rsi<35)text+=`RSI of ${analysis.rsi} indicates oversold conditions — a potential entry point. `;
  else if(analysis.rsi>70)text+=`RSI of ${analysis.rsi} signals overbought conditions — consider waiting for a pullback. `;
  return text;
}

function buildVerdictPoints(ticker, quote, metrics, analysis, target) {
  const m=metrics?.metric||{};
  const points=[];
  const pe=m['peNormalizedAnnual'],roe=m['roeTTM'],debtEq=m['totalDebt/totalEquityAnnual'],revenueGrowth=m['revenueGrowthTTMYoy'];
  const upside=target?.targetMean?((target.targetMean-quote.c)/quote.c*100):null;
  if(analysis.macd.bullish)points.push({icon:'✅',text:'MACD bullish crossover — positive momentum signal'});
  else points.push({icon:'⚠️',text:'MACD bearish — momentum trend is negative'});
  if(analysis.sma50&&quote.c>analysis.sma50)points.push({icon:'✅',text:`Trading above 50-day SMA ($${analysis.sma50.toFixed(2)}) — medium-term uptrend intact`});
  else if(analysis.sma50)points.push({icon:'🔴',text:`Below 50-day SMA ($${analysis.sma50.toFixed(2)}) — medium-term downtrend`});
  if(analysis.sma200&&quote.c>analysis.sma200)points.push({icon:'✅',text:`Above 200-day SMA ($${analysis.sma200.toFixed(2)}) — long-term bullish structure`});
  else if(analysis.sma200)points.push({icon:'⚠️',text:`Below 200-day SMA ($${analysis.sma200.toFixed(2)}) — long-term bearish`});
  if(pe&&pe<20)points.push({icon:'✅',text:`P/E of ${pe.toFixed(1)}x represents compelling value vs. sector peers`});
  else if(pe&&pe>50)points.push({icon:'⚠️',text:`P/E of ${pe.toFixed(1)}x is elevated — priced for perfection`});
  if(roe&&roe>20)points.push({icon:'✅',text:`ROE of ${roe.toFixed(1)}% signals a high-quality business with durable competitive advantages`});
  else if(roe&&roe<5)points.push({icon:'🔴',text:`ROE of ${roe.toFixed(1)}% is below acceptable threshold`});
  if(debtEq&&debtEq<50)points.push({icon:'✅',text:`Clean balance sheet — D/E of ${debtEq.toFixed(0)}% gives financial flexibility`});
  else if(debtEq&&debtEq>200)points.push({icon:'🔴',text:`High leverage (${debtEq.toFixed(0)}% D/E) — increased financial risk`});
  if(revenueGrowth&&revenueGrowth>15)points.push({icon:'✅',text:`Revenue growing at ${revenueGrowth.toFixed(1)}% YoY — top-line momentum strong`});
  else if(revenueGrowth&&revenueGrowth<0)points.push({icon:'🔴',text:`Revenue declining ${revenueGrowth.toFixed(1)}% YoY — fundamental concern`});
  if(upside&&upside>15)points.push({icon:'✅',text:`Analyst consensus implies ${upside.toFixed(1)}% upside — Wall Street is bullish`});
  else if(upside&&upside<-5)points.push({icon:'🔴',text:`Analyst targets below current price — consensus is bearish`});
  if(analysis.rsi<35)points.push({icon:'✅',text:`RSI ${analysis.rsi} — technically oversold, historically a buy signal`});
  else if(analysis.rsi>75)points.push({icon:'⚠️',text:`RSI ${analysis.rsi} — overbought territory, elevated short-term risk`});
  return points.map(p=>`<div class="verdict-point"><span style="flex-shrink:0;">${p.icon}</span><span>${p.text}</span></div>`).join('');
}

async function runAIAnalysis(ticker, quote, profile, metrics, analysis, target, recommendation) {
  const m = metrics?.metric || {};
  document.getElementById('ai-verdict-content').innerHTML = '<div class="ai-thinking"><div class="ai-spinner"></div> Claude AI is analyzing ' + ticker + '...</div>';
  const prompt = `You are a senior Goldman Sachs equity analyst. Analyze ${ticker} (${profile.name || ticker}) and give a concise institutional-grade investment thesis.

Key data:
- Price: $${quote.c?.toFixed(2)} (${quote.dp >= 0 ? '+' : ''}${quote.dp?.toFixed(2)}% today)
- Market Cap: ${profile.marketCapitalization ? '$' + (profile.marketCapitalization / 1000).toFixed(1) + 'B' : 'N/A'}
- Sector: ${profile.finnhubIndustry || 'N/A'}
- P/E: ${m['peNormalizedAnnual']?.toFixed(1) || 'N/A'}
- ROE: ${m['roeTTM']?.toFixed(1) || 'N/A'}%
- Net Margin: ${m['netProfitMarginTTM']?.toFixed(1) || 'N/A'}%
- Revenue Growth YoY: ${m['revenueGrowthTTMYoy']?.toFixed(1) || 'N/A'}%
- Debt/Equity: ${m['totalDebt/totalEquityAnnual']?.toFixed(0) || 'N/A'}%
- RSI: ${analysis.rsi}
- MACD: ${analysis.macd.bullish ? 'Bullish' : 'Bearish'}
- Above SMA50: ${analysis.sma50 && quote.c > analysis.sma50 ? 'Yes' : 'No'}
- Analyst consensus score: ${analysis.sentScore}/100
- Analyst price target: ${target?.targetMean ? '$' + target.targetMean.toFixed(2) : 'N/A'}
- Overall score: ${analysis.overall}/100 — ${analysis.verdict}

Write a 3-paragraph institutional analysis:
1. INVESTMENT THESIS: Core bull or bear case in 2-3 sentences
2. KEY RISKS: Top 2-3 risks that could derail the thesis
3. RECOMMENDATION: Clear stance with a 12-month price target range and catalyst to watch

Be direct, data-driven, and institutional. No fluff.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const data = await response.json();
    const text = data.content?.[0]?.text || 'Analysis unavailable.';
    const formatted = text.split('\n').filter(l => l.trim()).map(line => {
      if (line.startsWith('1.') || line.startsWith('2.') || line.startsWith('3.') || line.match(/^[A-Z ]{4,}:/)) {
        return `<div style="font-family:var(--font-display);font-size:14px;letter-spacing:1px;color:var(--gold2);margin-top:14px;margin-bottom:6px;">${line}</div>`;
      }
      return `<div style="font-size:13px;line-height:1.8;color:var(--text);margin-bottom:4px;">${line}</div>`;
    }).join('');
    document.getElementById('ai-verdict-content').innerHTML = `
      <div class="ai-verdict">
        <div class="ai-verdict-title">🤖 AI DEEP ANALYSIS — ${ticker}</div>
        <div class="ai-verdict-text">${formatted}</div>
      </div>`;
  } catch(e) {
    document.getElementById('ai-verdict-content').innerHTML = '<div style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">AI analysis unavailable — data displayed above is complete.</div>';
  }
}

function drawChart(closes, volumes) {
  const canvas = document.getElementById('price-chart');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth || 600;
  canvas.height = 130;
  if (!closes || closes.length < 2) {
    ctx.fillStyle = 'rgba(74,96,128,0.3)';
    ctx.font = '11px DM Mono';
    ctx.fillText('No chart data available', 20, 65);
    return;
  }
  const data = closes.slice(-60);
  const vols = volumes?.slice(-60) || [];
  const min = Math.min(...data), max = Math.max(...data), range = max - min || 1;
  const W = canvas.width, H = canvas.height;
  const pad = {t:8,b:24,l:8,r:8};
  const chartH = H - pad.t - pad.b - 20;
  const volH = 18;
  ctx.clearRect(0,0,W,H);

  // Grid
  ctx.strokeStyle='rgba(26,40,64,0.8)';ctx.lineWidth=1;
  for(let i=0;i<=3;i++){const y=pad.t+(chartH/3)*i;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke();}

  const xS = i => pad.l+(i/(data.length-1))*(W-pad.l-pad.r);
  const yS = v => pad.t+chartH-((v-min)/range)*chartH;
  const isUp = data[data.length-1] >= data[0];

  // Volume bars
  if(vols.length){
    const maxVol=Math.max(...vols.filter(Boolean));
    vols.forEach((v,i)=>{
      if(!v)return;
      const x=xS(i),bh=(v/maxVol)*volH;
      ctx.fillStyle=isUp?'rgba(0,230,118,0.2)':'rgba(255,61,87,0.2)';
      ctx.fillRect(x-1,H-pad.b-bh,2,bh);
    });
  }

  // Gradient
  const grad=ctx.createLinearGradient(0,pad.t,0,H-pad.b);
  grad.addColorStop(0,isUp?'rgba(0,230,118,0.2)':'rgba(255,61,87,0.2)');
  grad.addColorStop(1,'rgba(0,0,0,0)');
  ctx.beginPath();ctx.moveTo(xS(0),yS(data[0]));
  for(let i=1;i<data.length;i++)ctx.lineTo(xS(i),yS(data[i]));
  ctx.lineTo(xS(data.length-1),H-pad.b);ctx.lineTo(xS(0),H-pad.b);
  ctx.closePath();ctx.fillStyle=grad;ctx.fill();

  // Price line
  ctx.beginPath();ctx.moveTo(xS(0),yS(data[0]));
  for(let i=1;i<data.length;i++)ctx.lineTo(xS(i),yS(data[i]));
  ctx.strokeStyle=isUp?'var(--green)':'var(--red)';ctx.lineWidth=1.5;ctx.stroke();

  // Labels
  ctx.fillStyle='rgba(107,133,160,0.9)';ctx.font='10px DM Mono';
  ctx.fillText('$'+min.toFixed(0),pad.l,H-pad.b+12);
  ctx.fillText('$'+max.toFixed(0),pad.l,pad.t+10);
  ctx.fillText('60D',W-pad.r-22,H-pad.b+12);
  ctx.fillText(isUp?'▲':'▼',W-pad.r-12,pad.t+10);
}
