    <div class="panel">
      <div class="panel-header"><span class="panel-title">INSIDER TRADING</span><span class="panel-badge badge-purple" id="insider-badge">LOADING</span></div>
      <div class="panel-body" id="insider-metrics"><div style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">Loading insider data...</div></div>
    </div>
