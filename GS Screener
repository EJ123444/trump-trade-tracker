
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GS Elite Stock Analyzer</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#04080f;--bg2:#080e1a;--bg3:#0d1525;--bg4:#111d30;
  --border:#1a2840;--border2:#243550;
  --text:#e2e8f0;--muted:#4a6080;--muted2:#6b85a0;
  --gold:#c9a84c;--gold2:#e8c96a;--goldg:linear-gradient(135deg,#c9a84c,#e8c96a);
  --green:#00e676;--red:#ff3d57;--blue:#2979ff;--cyan:#00b4d8;--purple:#9c27b0;
  --font-display:'Bebas Neue',sans-serif;
  --font-mono:'DM Mono',monospace;
  --font-sans:'DM Sans',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--font-sans);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:0.4;}
.header{padding:0 32px;height:64px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:var(--bg);position:sticky;top:0;z-index:100;}
.logo-main{font-family:var(--font-display);font-size:28px;letter-spacing:3px;background:var(--goldg);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.logo-sub{font-family:var(--font-mono);font-size:10px;color:var(--muted2);letter-spacing:2px;}
.live-pill{display:flex;align-items:center;gap:6px;background:rgba(0,230,118,0.08);border:1px solid rgba(0,230,118,0.2);border-radius:20px;padding:4px 12px;font-family:var(--font-mono);font-size:11px;color:var(--green);}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 1.5s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
.time-display{font-family:var(--font-mono);font-size:12px;color:var(--muted2);}
.search-hero{padding:48px 32px 32px;text-align:center;position:relative;}
.search-hero::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:600px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.hero-label{font-family:var(--font-mono);font-size:11px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:16px;}
.hero-title{font-family:var(--font-display);font-size:52px;letter-spacing:4px;line-height:1;margin-bottom:8px;}
.hero-sub{font-size:13px;color:var(--muted2);margin-bottom:32px;}
.search-wrap{position:relative;max-width:600px;margin:0 auto;}
.search-input{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:16px 130px 16px 20px;font-family:var(--font-mono);font-size:16px;color:var(--text);outline:none;transition:all 0.2s;letter-spacing:1px;}
.search-input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,0.1);}
.search-input::placeholder{color:var(--muted);font-size:13px;letter-spacing:0}
.search-btn{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:var(--goldg);border:none;border-radius:3px;padding:8px 16px;font-family:var(--font-mono);font-size:12px;font-weight:500;color:#04080f;cursor:pointer;letter-spacing:1px;transition:opacity 0.2s;}
.search-btn:hover{opacity:0.85;}
.quick-picks{display:flex;gap:8px;justify-content:center;margin-top:16px;flex-wrap:wrap;}
.quick-pill{font-family:var(--font-mono);font-size:11px;padding:4px 12px;border:1px solid var(--border2);border-radius:20px;color:var(--muted2);cursor:pointer;transition:all 0.15s;background:transparent;}
.quick-pill:hover{border-color:var(--gold);color:var(--gold);}
.analysis{padding:32px;display:none;}
.analysis.visible{display:block;animation:fadeIn 0.4s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.score-banner{display:grid;grid-template-columns:200px 1fr;gap:0;margin-bottom:24px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden;}
.score-left{padding:28px;background:linear-gradient(135deg,var(--bg3),var(--bg2));border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;}
.score-number{font-family:var(--font-display);font-size:72px;line-height:1;}
.score-label{font-family:var(--font-mono);font-size:10px;letter-spacing:2px;color:var(--muted2);text-transform:uppercase;}
.score-verdict{font-family:var(--font-display);font-size:18px;letter-spacing:2px;}
.score-right{padding:24px 28px;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.score-metric{display:flex;flex-direction:column;gap:4px;}
.score-metric-label{font-family:var(--font-mono);font-size:9px;letter-spacing:1.5px;color:var(--muted);text-transform:uppercase;}
.score-metric-value{font-family:var(--font-mono);font-size:18px;font-weight:500;}
.score-metric-sub{font-size:11px;color:var(--muted2);}
.section-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.panel{background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden;}
.panel-header{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.panel-title{font-family:var(--font-display);font-size:16px;letter-spacing:2px;color:var(--text);}
.panel-badge{font-family:var(--font-mono);font-size:10px;padding:3px 10px;border-radius:2px;letter-spacing:1px;}
.badge-green{background:rgba(0,230,118,0.1);color:var(--green);border:1px solid rgba(0,230,118,0.2);}
.badge-red{background:rgba(255,61,87,0.1);color:var(--red);border:1px solid rgba(255,61,87,0.2);}
.badge-gold{background:rgba(201,168,76,0.1);color:var(--gold2);border:1px solid rgba(201,168,76,0.2);}
.badge-blue{background:rgba(41,121,255,0.1);color:#6ba3ff;border:1px solid rgba(41,121,255,0.2);}
.badge-purple{background:rgba(156,39,176,0.1);color:#ce93d8;border:1px solid rgba(156,39,176,0.2);}
.panel-body{padding:20px;}
.metric-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(26,40,64,0.6);}
.metric-row:last-child{border-bottom:none;}
.metric-name{font-family:var(--font-mono);font-size:12px;color:var(--muted2);min-width:140px;}
.metric-val{font-family:var(--font-mono);font-size:13px;font-weight:500;}
.metric-bar-wrap{display:flex;align-items:center;gap:10px;flex:1;margin:0 16px;}
.metric-bar{height:3px;background:var(--bg4);border-radius:2px;flex:1;overflow:hidden;}
.metric-bar-fill{height:100%;border-radius:2px;transition:width 1.2s ease;}
.metric-note{font-size:10px;color:var(--muted);font-family:var(--font-mono);white-space:nowrap;}
.gauge-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.gauge{text-align:center;padding:14px 8px;}
.gauge-value{font-family:var(--font-display);font-size:26px;letter-spacing:1px;margin-bottom:4px;}
.gauge-label{font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}
.gauge-sub{font-size:11px;color:var(--muted2);margin-top:2px;}
.verdict-box{background:linear-gradient(135deg,rgba(201,168,76,0.05),rgba(201,168,76,0.02));border:1px solid rgba(201,168,76,0.2);border-radius:4px;padding:20px;}
.verdict-title{font-family:var(--font-display);font-size:20px;letter-spacing:2px;color:var(--gold2);margin-bottom:12px;}
.verdict-text{font-size:13px;line-height:1.7;color:var(--muted2);}
.verdict-points{margin-top:12px;display:flex;flex-direction:column;gap:6px;}
.verdict-point{display:flex;gap:10px;font-size:12px;color:var(--text);}
.ai-verdict{background:linear-gradient(135deg,rgba(156,39,176,0.08),rgba(41,121,255,0.05));border:1px solid rgba(156,39,176,0.2);border-radius:4px;padding:20px;margin-top:16px;}
.ai-verdict-title{font-family:var(--font-display);font-size:16px;letter-spacing:2px;color:#ce93d8;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.ai-verdict-text{font-size:13px;line-height:1.8;color:var(--text);}
.loading-overlay{position:fixed;inset:0;background:rgba(4,8,15,0.95);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:500;gap:16px;}
.loading-overlay.hidden{display:none;}
.loading-logo{font-family:var(--font-display);font-size:40px;letter-spacing:4px;background:var(--goldg);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.loading-bar-wrap{width:300px;height:2px;background:var(--border);}
.loading-bar{height:100%;background:var(--goldg);width:0%;transition:width 0.3s;}
.loading-status{font-family:var(--font-mono);font-size:11px;color:var(--muted2);letter-spacing:1px;}
.divider-line{height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);margin:4px 0;}
.tag-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;}
.tag{font-family:var(--font-mono);font-size:10px;padding:3px 8px;border-radius:2px;border:1px solid var(--border2);color:var(--muted2);}
.earnings-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(255,204,0,0.08);border:1px solid rgba(255,204,0,0.2);border-radius:4px;padding:6px 12px;font-family:var(--font-mono);font-size:11px;color:var(--yellow,#ffcc00);}
.signal-pill{display:inline-flex;align-items:center;gap:6px;border-radius:4px;padding:6px 12px;font-family:var(--font-mono);font-size:12px;font-weight:600;letter-spacing:1px;}
.signal-buy{background:rgba(0,230,118,0.1);color:var(--green);border:1px solid rgba(0,230,118,0.3);}
.signal-sell{background:rgba(255,61,87,0.1);color:var(--red);border:1px solid rgba(255,61,87,0.3);}
.signal-hold{background:rgba(201,168,76,0.1);color:var(--gold2);border:1px solid rgba(201,168,76,0.3);}
.insider-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(26,40,64,0.5);}
.insider-row:last-child{border-bottom:none;}
.insider-name{font-size:12px;color:var(--text);}
.insider-meta{font-family:var(--font-mono);font-size:10px;color:var(--muted2);}
.insider-val{font-family:var(--font-mono);font-size:12px;font-weight:500;}
.ai-thinking{display:flex;align-items:center;gap:8px;color:var(--muted2);font-family:var(--font-mono);font-size:12px;}
.ai-spinner{width:12px;height:12px;border:2px solid var(--border);border-top-color:#ce93d8;border-radius:50%;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
canvas{display:block;width:100%;}
@media(max-width:768px){
  .search-hero{padding:32px 16px 24px;}
  .hero-title{font-size:36px;}
  .analysis{padding:16px;}
  .score-banner{grid-template-columns:1fr;}
  .score-right{grid-template-columns:repeat(2,1fr);}
  .section-grid{grid-template-columns:1fr;}
  .gauge-row{grid-template-columns:repeat(2,1fr);}
}
</style>
</head>
<body>

<div class="loading-overlay hidden" id="loading-overlay">
  <div class="loading-logo">ANALYZING</div>
  <div class="loading-bar-wrap"><div class="loading-bar" id="loading-bar"></div></div>
  <div class="loading-status" id="loading-status">Connecting to market data...</div>
</div>

<div class="header">
  <div style="display:flex;align-items:baseline;gap:10px;">
    <div class="logo-main">ELITE ANALYZER</div>
    <div class="logo-sub">INSTITUTIONAL GRADE · POWERED BY AI</div>
  </div>
  <div style="display:flex;align-items:center;gap:16px;">
    <div class="live-pill"><div class="live-dot"></div>LIVE DATA</div>
