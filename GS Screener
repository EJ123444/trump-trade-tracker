      <div class="panel-header"><span class="panel-title">EARNINGS & EVENTS</span><span class="panel-badge badge-gold" id="earnings-badge">LOADING</span></div>
      <div class="panel-body" id="earnings-metrics"><div style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">Loading earnings data...</div></div>
