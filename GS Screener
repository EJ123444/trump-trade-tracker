<script>
const FINNHUB_KEY = 'd8ec5fhr01qth3cgkulgd8ec5fhr01qth3cgkum0';

// Clock
setInterval(() => {
  document.getElementById('clock').textContent = new Date().toLocaleTimeString('en-US',{hour12:true});
}, 1000);

function quickPick(t) {
  document.getElementById('ticker-input').value = t;
  analyze();
}

document.getElementById('ticker-input').addEventListener('keypress', e => { if(e.key==='Enter') analyze(); });

function setLoading(pct, msg) {
  document.getElementById('loading-bar').style.width = pct+'%';
  document.getElementById('loading-status').textContent = msg;
}

async function finnhubGet(path) {
  const r = await fetch(`https://finnhub.io/api/v1${path}&token=${FINNHUB_KEY}`);
  return r.json();
}

async function analyze() {
  const ticker = document.getElementById('ticker-input').value.trim().toUpperCase();
  if (!ticker) return;

  // Show loading
  const overlay = document.getElementById('loading-overlay');
  overlay.classList.remove('hidden');
  setLoading(0, 'Connecting to market data...');

  try {
    document.getElementById('analysis-panel').classList.remove('visible');

    setLoading(10, `Fetching ${ticker} quote...`);
    const [quote, profile, metrics, candles, recommendation, target] = await Promise.all([
      finnhubGet(`/quote?symbol=${ticker}`),
      finnhubGet(`/stock/profile2?symbol=${ticker}`),
      finnhubGet(`/stock/metric?symbol=${ticker}&metric=all`),
      (async () => {
        const to = Math.floor(Date.now()/1000);
        const from = to - 86400*90;
        return finnhubGet(`/stock/candle?symbol=${ticker}&resolution=D&from=${from}&to=${to}`);
      })(),
      finnhubGet(`/stock/recommendation?symbol=${ticker}`),
      finnhubGet(`/stock/price-target?symbol=${ticker}`)
    ]);

    setLoading(60, 'Processing technical indicators...');
    if (!quote.c || quote.c === 0) throw new Error('Ticker not found');

    setLoading(75, 'Running fundamental analysis...');
    const analysis = buildAnalysis(ticker, quote, profile, metrics, candles, recommendation, target);

    setLoading(90, 'Generating GS verdict...');
    renderAll(ticker, quote, profile, metrics, candles, recommendation, target, analysis);

    setLoading(100, 'Complete');
    setTimeout(() => {
      overlay.classList.add('hidden');
      document.getElementById('analysis-panel').classList.add('visible');
      document.getElementById('analysis-panel').scrollIntoView({behavior:'smooth'});
    }, 400);

  } catch(e) {
    overlay.classList.add('hidden');
    alert('Could not find data for "'+ticker+'". Check the ticker symbol and try again.');
  }
}

function calcRSI(closes, period=14) {
  if (closes.length < period+1) return 50;
  let gains=0, losses=0;
  for (let i=closes.length-period; i<closes.length; i++) {
    const d = closes[i]-closes[i-1];
    if (d>0) gains+=d; else losses+=Math.abs(d);
  }
  const ag=gains/period, al=losses/period;
  if (al===0) return 100;
  return Math.round(100-(100/(1+ag/al)));
}

function calcMACD(closes) {
  if (closes.length < 26) return {macd:0, signal:0, hist:0};
  const ema=(arr,p)=>{
    const k=2/(p+1); let e=arr[0];
    for(let i=1;i<arr.length;i++) e=arr[i]*k+e*(1-k);
    return e;
  };
  const recent = closes.slice(-35);
  const ema12=ema(recent,12), ema26=ema(recent,26);
  const macd=ema12-ema26;
  return {macd:macd.toFixed(2), bullish: macd>0};
}

function calcSMA(closes, period) {
  if (closes.length < period) return null;
  return closes.slice(-period).reduce((a,b)=>a+b,0)/period;
}

function fmtB(n) {
  if (!n) return '—';
  if (Math.abs(n) >= 1e12) return '$'+(n/1e12).toFixed(2)+'T';
  if (Math.abs(n) >= 1e9) return '$'+(n/1e9).toFixed(2)+'B';
  if (Math.abs(n) >= 1e6) return '$'+(n/1e6).toFixed(2)+'M';
  return '$'+n.toFixed(0);
}
function fmtN(n, decimals=2) { return n != null && !isNaN(n) ? n.toFixed(decimals) : '—'; }
function fmtPct(n) { return n != null && !isNaN(n) ? (n>0?'+':'')+n.toFixed(1)+'%' : '—'; }
function scoreColor(s) { return s>=75?'var(--green)':s>=50?'var(--gold2)':s>=30?'var(--gold)':'var(--red)'; }

function buildAnalysis(ticker, quote, profile, metrics, candles, recommendation, target) {
  const m = metrics?.metric || {};
  const closes = candles?.c || [];
  const rsi = calcRSI(closes);
  const macd = calcMACD(closes);
  const sma20 = calcSMA(closes, 20);
  const sma50 = calcSMA(closes, 50);
  const price = quote.c;

  // Technical score (0-100)
  let techScore = 50;
  if (rsi > 30 && rsi < 70) techScore += 10;
  if (rsi < 40) techScore += 15; // oversold = opportunity
  if (rsi > 70) techScore -= 10; // overbought
  if (macd.bullish) techScore += 15;
  if (sma20 && price > sma20) techScore += 10;
  if (sma50 && price > sma50) techScore += 10;
  const chg = quote.dp || 0;
  if (chg > 0) techScore += 5;
  techScore = Math.max(5, Math.min(98, techScore));

  // Fundamental score
  let fundScore = 50;
  const pe = m['peNormalizedAnnual'];
  const pb = m['pbAnnual'];
  const roe = m['roeTTM'];
  const margin = m['netProfitMarginTTM'];
  const debtEq = m['totalDebt/totalEquityAnnual'];
  if (pe && pe > 0 && pe < 30) fundScore += 15;
  if (pe && pe > 30 && pe < 60) fundScore += 5;
  if (pe && pe > 60) fundScore -= 10;
  if (roe && roe > 15) fundScore += 15;
  if (roe && roe > 30) fundScore += 5;
  if (margin && margin > 15) fundScore += 10;
  if (margin && margin > 25) fundScore += 5;
  if (debtEq && debtEq < 50) fundScore += 10;
  if (debtEq && debtEq > 200) fundScore -= 15;
  fundScore = Math.max(5, Math.min(98, fundScore));

  // Valuation score
  let valScore = 50;
  const priceToBook = m['pbAnnual'];
  const evEbitda = m['currentEv/freeCashFlowTTM'];
  if (pe && pe > 0 && pe < 20) valScore += 20;
  else if (pe && pe < 35) valScore += 10;
  else if (pe && pe > 50) valScore -= 15;
  if (priceToBook && priceToBook < 3) valScore += 15;
  if (priceToBook && priceToBook > 10) valScore -= 10;
  valScore = Math.max(5, Math.min(98, valScore));

  // Analyst score
  let sentScore = 50;
  if (recommendation && recommendation.length > 0) {
    const latest = recommendation[0];
    const total = (latest.strongBuy||0)+(latest.buy||0)+(latest.hold||0)+(latest.sell||0)+(latest.strongSell||0);
    if (total > 0) {
      const bullish = ((latest.strongBuy||0)*2+(latest.buy||0)) / total * 100;
      sentScore = Math.round(bullish * 0.8 + 20);
    }
  }
  if (target?.targetMean && price) {
    const upside = (target.targetMean - price)/price*100;
    if (upside > 20) sentScore += 15;
    else if (upside > 10) sentScore += 8;
    else if (upside < 0) sentScore -= 15;
  }
  sentScore = Math.max(5, Math.min(98, sentScore));

  const overall = Math.round((techScore*0.25 + fundScore*0.30 + valScore*0.25 + sentScore*0.20));

  let verdict, verdictColor;
  if (overall >= 75) { verdict = 'STRONG BUY'; verdictColor = 'var(--green)'; }
  else if (overall >= 62) { verdict = 'BUY'; verdictColor = 'var(--green)'; }
  else if (overall >= 45) { verdict = 'HOLD'; verdictColor = 'var(--gold2)'; }
  else if (overall >= 32) { verdict = 'UNDERPERFORM'; verdictColor = 'var(--red)'; }
  else { verdict = 'SELL'; verdictColor = 'var(--red)'; }

  return { techScore, fundScore, valScore, sentScore, overall, verdict, verdictColor, rsi, macd, sma20, sma50 };
}

function metricRow(name, value, barPct, barColor, note='') {
  return `<div class="metric-row">
    <span class="metric-name">${name}</span>
    <div class="metric-bar-wrap">
      <div class="metric-bar"><div class="metric-bar-fill" style="width:${Math.min(100,Math.max(0,barPct))}%;background:${barColor};"></div></div>
    </div>
    <span class="metric-val">${value}</span>
    ${note?`<span class="metric-note" style="margin-left:8px;">${note}</span>`:''}
  </div>`;
}

